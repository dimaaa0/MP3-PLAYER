generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id           String      @id @default(cuid())
  userId       String?
  name         String   @default("")
  createdAt    DateTime @default(now())
  randomNumber Float    @default(0)

  @@index([userId, name])
  @@index([createdAt])
} 

model Track {
  id        String   @id @default(uuid())
  name      String
  artist    String
  duration  Int      
  imageUrl  String?
  slug      String   @unique 

  favorites FavoriteTrack[]
  
  playlists PlaylistTrack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Playlist {
  id          String   @id @default(uuid())
  title       String
  description String?
  userId      String
  
  tracks      PlaylistTrack[]

  createdAt   DateTime @default(now())
}

model PlaylistTrack {
  trackId    String
  playlistId String
  addedAt    DateTime @default(now()) 

  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([trackId, playlistId]) 
}

model FavoriteTrack {
  id        String   @id @default(uuid())
  userId    String   
  trackId   String 
  
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) 

  @@unique([trackId, userId])
}
