generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// model User {
//   id    Int     @id @default(autoincrement())
//   email String  @unique
//   name  String?
// }

model Post {
  id           String      @id @default(cuid())
  userId       String?
  name         String   @default("")
  createdAt    DateTime @default(now())
  randomNumber Float    @default(0)

  @@index([userId, name])
  @@index([createdAt])
  // author       User?    @relation(fields: [userId], references: [id])
} 
